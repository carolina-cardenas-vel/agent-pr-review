{
  "servers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "tools": [
        "get_pull_request",
        "get_pull_request_files",
        "get_file_contents",
        "create_pull_request_review",
        "list_pull_requests"
      ]
    },
    "azure-devops": {
      "type": "http",
      "url": "https://mcp.dev.azure.com/${input:ado_org}"
    }
  },
  "inputs": [
    {
      "type": "promptString",
      "id": "ado_org",
      "description": "Azure DevOps organization name (e.g., contoso — the part after dev.azure.com/)",
      "password": false
    }
  ]
}
